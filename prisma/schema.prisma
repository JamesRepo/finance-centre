generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DebtType {
  CREDIT_CARD
  STUDENT_LOAN
  PERSONAL_LOAN
  OTHER
}

enum SavingsPriority {
  LOW
  MEDIUM
  HIGH
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  colorCode String?  @map("color_code")
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")

  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id              String   @id @default(cuid())
  categoryId      String   @map("category_id")
  amount          Decimal
  transactionDate DateTime @map("transaction_date")
  description     String?
  vendor          String?
  createdAt       DateTime @default(now()) @map("created_at")

  category  Category              @relation(fields: [categoryId], references: [id])
  lineItems TransactionLineItem[]

  @@map("transactions")
}

model TransactionLineItem {
  id            String   @id @default(cuid())
  transactionId String   @map("transaction_id")
  amount        Decimal
  sortOrder     Int      @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_line_items")
}

model Budget {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  amount     Decimal
  month      DateTime
  createdAt  DateTime @default(now()) @map("created_at")

  category Category @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, month])
  @@map("budgets")
}

model Debt {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(100)
  debtType         DebtType  @map("debt_type")
  originalBalance  Decimal   @map("original_balance")
  interestRate     Decimal   @map("interest_rate")
  minimumPayment   Decimal?  @map("minimum_payment")
  startDate        DateTime? @map("start_date")
  targetPayoffDate DateTime? @map("target_payoff_date")
  isActive         Boolean   @default(true) @map("is_active")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  debtPayments DebtPayment[]

  @@map("debts")
}

model DebtPayment {
  id             Int      @id @default(autoincrement())
  debtId         Int      @map("debt_id")
  amount         Decimal
  interestAmount Decimal  @default(0) @map("interest_amount")
  paymentDate    DateTime @map("payment_date")
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@map("debt_payments")
}

model SavingsGoal {
  id           Int              @id @default(autoincrement())
  name         String           @db.VarChar(100)
  targetAmount Decimal          @map("target_amount")
  targetDate   DateTime?        @map("target_date")
  priority     SavingsPriority?
  createdAt    DateTime         @default(now()) @map("created_at")

  savingsContributions SavingsContribution[]

  @@map("savings_goals")
}

model SavingsContribution {
  id               Int      @id @default(autoincrement())
  goalId           Int      @map("goal_id")
  amount           Decimal
  contributionDate DateTime @map("contribution_date")
  note             String?
  createdAt        DateTime @default(now()) @map("created_at")

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("savings_contributions")
}

model HousingExpense {
  id           Int      @id @default(autoincrement())
  expenseType  String   @map("expense_type")
  amount       Decimal
  expenseMonth DateTime @map("expense_month")
  frequency    String
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([expenseType, expenseMonth])
  @@map("housing_expenses")
}

model Subscription {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(200)
  amount       Decimal
  frequency    String
  paymentDate  DateTime @map("payment_date")
  paymentMonth DateTime @map("payment_month")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([name, paymentMonth])
  @@map("subscriptions")
}

model IncomeSource {
  id                   Int      @id @default(autoincrement())
  incomeType           String   @map("income_type")
  description          String?
  grossAmount          Decimal  @map("gross_amount")
  netAmount            Decimal  @map("net_amount")
  incomeDate           DateTime @map("income_date")
  isRecurring          Boolean  @default(false) @map("is_recurring")
  recurrenceFrequency  String?  @map("recurrence_frequency")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")

  incomeDeductions IncomeDeduction[]

  @@map("income_sources")
}

model IncomeDeduction {
  id              Int      @id @default(autoincrement())
  incomeSourceId  Int      @map("income_source_id")
  deductionType   String   @map("deduction_type")
  name            String   @db.VarChar(255)
  amount          Decimal
  isPercentage    Boolean  @default(false) @map("is_percentage")
  percentageValue Decimal? @map("percentage_value")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  incomeSource IncomeSource @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)

  @@map("income_deductions")
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  destination String   @db.VarChar(200)
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  holidayExpenses HolidayExpense[]

  @@map("holidays")
}

model HolidayExpense {
  id          Int      @id @default(autoincrement())
  holidayId   Int      @map("holiday_id")
  expenseType String   @map("expense_type")
  description String   @db.VarChar(500)
  amount      Decimal
  expenseDate DateTime @map("expense_date")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  holiday Holiday @relation(fields: [holidayId], references: [id], onDelete: Cascade)

  @@map("holiday_expenses")
}

model Settings {
  id                 Int      @id @default(autoincrement())
  currency           String   @default("GBP")
  locale             String   @default("en-GB")
  theme              String   @default("light")
  monthlyBudgetTotal Decimal? @map("monthly_budget_total")
  email              String?
  passwordHash       String?  @map("password_hash")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
