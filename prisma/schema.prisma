generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DebtType {
  CREDIT_CARD
  STUDENT_LOAN
  PERSONAL_LOAN
  OTHER
}

enum SavingsPriority {
  LOW
  MEDIUM
  HIGH
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  colorCode String?  @map("color_code")
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")

  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id              String   @id @default(cuid())
  categoryId      String   @map("category_id")
  amount          Decimal
  transactionDate DateTime @map("transaction_date")
  description     String?
  vendor          String?
  createdAt       DateTime @default(now()) @map("created_at")

  category Category @relation(fields: [categoryId], references: [id])

  @@map("transactions")
}

model Budget {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  amount     Decimal
  month      DateTime
  createdAt  DateTime @default(now()) @map("created_at")

  category Category @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, month])
  @@map("budgets")
}

model Debt {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(100)
  debtType         DebtType  @map("debt_type")
  originalBalance  Decimal   @map("original_balance")
  interestRate     Decimal   @map("interest_rate")
  minimumPayment   Decimal?  @map("minimum_payment")
  startDate        DateTime? @map("start_date")
  targetPayoffDate DateTime? @map("target_payoff_date")
  isActive         Boolean   @default(true) @map("is_active")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  debtPayments DebtPayment[]

  @@map("debts")
}

model DebtPayment {
  id          Int      @id @default(autoincrement())
  debtId      Int      @map("debt_id")
  amount      Decimal
  paymentDate DateTime @map("payment_date")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  debt Debt @relation(fields: [debtId], references: [id])

  @@map("debt_payments")
}

model SavingsGoal {
  id           Int              @id @default(autoincrement())
  name         String           @db.VarChar(100)
  targetAmount Decimal          @map("target_amount")
  targetDate   DateTime?        @map("target_date")
  priority     SavingsPriority?
  createdAt    DateTime         @default(now()) @map("created_at")

  savingsContributions SavingsContribution[]

  @@map("savings_goals")
}

model SavingsContribution {
  id               Int      @id @default(autoincrement())
  goalId           Int      @map("goal_id")
  amount           Decimal
  contributionDate DateTime @map("contribution_date")
  note             String?
  createdAt        DateTime @default(now()) @map("created_at")

  goal SavingsGoal @relation(fields: [goalId], references: [id])

  @@map("savings_contributions")
}
